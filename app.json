{
  "expo": {
    "name": "Pileap",
    "slug": "pileap",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pileap",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pileap.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "package": "com.pileap.app",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "66797a5f-4add-47f4-943f-fe6b5dd41061"
      }
    },
    "owner": "sridevi123"
  }
}
