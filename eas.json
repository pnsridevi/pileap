{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_LEGACY_PEER_DEPS": "true" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "developmentClient": false,
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_LEGACY_PEER_DEPS": "true" }
    },
    "production": {}
  }
}